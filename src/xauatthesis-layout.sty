\NeedsTeXFormat{LaTeX2e}[2022/06/01]
\ProvidesFile{xauatthesis-layout.sty}
  [2026/05/06 v0.1 Page layout for XAUAT thesis template]

\InputIfFileExists{xauatthesis-fonts.cfg}
  {}
  {
    \PackageError{xauatthesis-layout}
      {Cannot find xauatthesis-fonts.cfg}
      {Keep the font configuration file in src/.}
  }

\makeatletter

\xauatifprint
  {
    \geometry{
      a4paper,
      top=3cm,
      bottom=2cm,
      inner=2.5cm,
      outer=2.5cm,
      bindingoffset=0.5cm,
      headheight=16pt,
      headsep=0.5cm,
      footskip=0.5cm
    }
  }
  {
    \geometry{
      a4paper,
      top=3cm,
      bottom=2cm,
      left=2.5cm,
      right=2.5cm,
      bindingoffset=0cm,
      headheight=16pt,
      headsep=0.5cm,
      footskip=0.5cm
    }
  }

\newcommand{\xauatblankpage}{%
  \clearpage
  \thispagestyle{xauat@empty}%
  \null
  \clearpage
}
\newcommand{\xauatcleardoublepage}{%
  \xauatifprint{\cleardoublepage}{\clearpage}%
}
\providecommand{\phantomsection}{}
\NewDocumentCommand{\xauat@chapter}{s o m o}{%
  \IfBooleanF{#1}{%
    \PackageError{xauatthesis-layout}
      {Use the starred form \string\xauat@chapter*}
      {Internal unnumbered chapters must use the starred form.}%
  }%
  \xauatcleardoublepage
  \IfValueTF{#2}{%
    \def\xauat@toc@entry{#2}%
    \ifx\xauat@toc@entry\@empty\else
      \phantomsection
      \addcontentsline{toc}{chapter}{#2}%
    \fi
  }{%
    \phantomsection
    \addcontentsline{toc}{chapter}{#3}%
  }%
  \chapter*{#3}%
  \IfValueTF{#4}{%
    \def\xauat@mark@entry{#4}%
    \ifx\xauat@mark@entry\@empty
      \markboth{}{}%
    \else
      \markboth{#4}{#4}%
    \fi
  }{%
    \markboth{#3}{#3}%
  }%
  \thispagestyle{xauat@plain}%
}
\newcommand{\xauatunnumberedchapter}[1]{\xauat@chapter*{#1}}
\newcommand{\xauatprelimchapter}[1]{%
  \xauat@chapter*[]{#1}%
}
\NewDocumentCommand{\xauat@startpage}{O{} m O{xauat@plain}}{%
  \xauatcleardoublepage
  \phantomsection
  \def\xauat@toc@entry{#1}%
  \ifx\xauat@toc@entry\@empty\else
    \addcontentsline{toc}{chapter}{#1}%
  \fi
  \markboth{#2}{#2}%
  \thispagestyle{#3}%
}
\newcommand{\xauatstartunnumberedpage}[2]{%
  \xauat@startpage[#1]{#2}%
}
\newcommand{\xauatstartfrontpage}[1]{%
  \xauat@startpage[]{#1}%
}
\NewDocumentCommand{\xauat@abstract@start}{o m}{%
  \IfValueTF{#1}
    {\xauatstartunnumberedpage{#1}{#2}}
    {\xauatstartunnumberedpage{#2}{#2}}%
}
\newlength{\xauat@toc@titleTopCenterDistance}
\setlength{\xauat@toc@titleTopCenterDistance}{0.7cm}
\newlength{\xauat@toc@titleContentCenterDistance}
\setlength{\xauat@toc@titleContentCenterDistance}{0.7cm}
\newlength{\xauat@toc@titleLineSkip}
\setlength{\xauat@toc@titleLineSkip}{0.5cm}
\newlength{\xauat@toc@entryLineSkip}
\setlength{\xauat@toc@entryLineSkip}{0.5cm}
\newcommand{\xauat@toc@title@font}{%
  \heiti\zihao{3}\setlength{\baselineskip}{\xauat@toc@titleLineSkip}\selectfont
}
\newcommand{\xauat@toc@start}[1]{%
  \xauatcleardoublepage
  \phantomsection
  \markboth{#1}{#1}%
  \thispagestyle{xauat@plain}%
  \begingroup
    \parindent\z@
    \vspace*{\dimexpr
      \xauat@toc@titleTopCenterDistance - 0.5\xauat@toc@titleLineSkip
    \relax}%
    {\centering\xauat@toc@title@font #1\par}%
    \vspace{\dimexpr
      \xauat@toc@titleContentCenterDistance
      - 0.5\xauat@toc@titleLineSkip
      - 0.5\xauat@toc@entryLineSkip
    \relax}%
  \endgroup
}
\newcommand{\xauat@list@start}[1]{%
  \xauat@chapter*{#1}%
}
\newlength{\xauat@denotation@titleTopCenterDistance}
\setlength{\xauat@denotation@titleTopCenterDistance}{0.7cm}
\newlength{\xauat@denotation@titleTableTopDistance}
\setlength{\xauat@denotation@titleTableTopDistance}{0.7cm}
\newlength{\xauat@denotation@titleLineSkip}
\setlength{\xauat@denotation@titleLineSkip}{0.5cm}
\newlength{\xauat@denotation@rowLineSkip}
\setlength{\xauat@denotation@rowLineSkip}{0.6cm}
\newcommand{\xauat@denotation@title@font}{%
  \heiti\zihao{3}\setlength{\baselineskip}{\xauat@denotation@titleLineSkip}\selectfont
}
\newcommand{\xauat@denotation@body@font}{%
  \normalfont\rmfamily\songti\zihao{-4}%
  \setlength{\baselineskip}{\xauat@denotation@rowLineSkip}\selectfont
}
\newcommand{\xauat@denotation@start}[1]{%
  \xauatcleardoublepage
  \phantomsection
  \addcontentsline{toc}{chapter}{#1}%
  \markboth{#1}{#1}%
  \thispagestyle{xauat@plain}%
  \begingroup
    \parindent\z@
    \vspace*{\dimexpr
      \xauat@denotation@titleTopCenterDistance - 0.5\xauat@denotation@titleLineSkip
    \relax}%
    {\centering\xauat@denotation@title@font #1\par}%
    \vspace{\dimexpr
      \xauat@denotation@titleTableTopDistance
      - 0.5\xauat@denotation@titleLineSkip
    \relax}%
  \endgroup
}
\newcommand{\xauat@mainchapter@start}[1]{%
  \chapter{#1}%
}
\newcommand{\xauat@bibliography@start}[1]{%
  \xauatunnumberedchapter{#1}%
}
\newcommand{\xauat@acknowledgements@start}[1]{%
  \xauatunnumberedchapter{#1}%
}
\newcommand{\xauat@appendix@start}[1]{%
  \chapter{#1}%
}
\newcommand{\xauat@achievement@start}[1]{%
  \xauatunnumberedchapter{#1}%
}
\newcommand{\xauatfrontpagination}{%
  \xauatcleardoublepage
  \pagenumbering{Roman}%
  \pagestyle{xauat@front}%
}
\renewcommand{\tableofcontents}{%
  \xauat@toc@start{\xauatContentsName}%
  \@starttoc{toc}%
}
\renewcommand{\listoffigures}{%
  \xauat@list@start{\listfigurename}%
  \@starttoc{lof}%
}
\renewcommand{\listoftables}{%
  \xauat@list@start{\listtablename}%
  \@starttoc{lot}%
}
\newcommand{\listoffiguresandtables}{%
  \listoffigures
  \listoftables
}
\newcommand{\xauatmaketableofcontents}{\tableofcontents}

\fancypagestyle{xauat@empty}{%
  \fancyhf{}%
  \renewcommand{\headrule}{}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
}

\newcommand{\xauat@headrule}{%
  \hrule height 1.2pt
  \vspace{0.6mm}%
  \hrule height 0.25pt
}
\newcommand{\xauat@headerfont}{\songti\zihao{5}}
\newcommand{\xauat@pagefont}{\normalfont\rmfamily\zihao{5}\selectfont}

\fancypagestyle{xauat@front}{%
  \fancyhf{}%
  \fancyhead[C]{\xauat@headerfont\leftmark}%
  \fancyfoot[RO,LE]{\xauat@pagefont\thepage}%
  \renewcommand{\headrule}{\xauat@headrule}%
  \renewcommand{\footrulewidth}{0pt}%
}

\fancypagestyle{xauat@main}{%
  \fancyhf{}%
  \fancyhead[CO]{\xauat@headerfont\leftmark}%
  \fancyhead[CE]{\xauat@headerfont\xauatUniversityCN\xauatDegreePaperCN}%
  \fancyfoot[RO,LE]{\xauat@pagefont\thepage}%
  \renewcommand{\headrule}{\xauat@headrule}%
  \renewcommand{\footrulewidth}{0pt}%
}

\fancypagestyle{xauat@plain}{%
  \fancyhf{}%
  \fancyhead[CO]{\xauat@headerfont\leftmark}%
  \fancyhead[CE]{\if@mainmatter\xauat@headerfont\xauatUniversityCN\xauatDegreePaperCN\else\xauat@headerfont\leftmark\fi}%
  \fancyfoot[RO,LE]{\xauat@pagefont\thepage}%
  \renewcommand{\headrule}{\xauat@headrule}%
  \renewcommand{\footrulewidth}{0pt}%
}
\fancypagestyle{plain}{%
  \fancyhf{}%
  \fancyhead[CO]{\xauat@headerfont\leftmark}%
  \fancyhead[CE]{\if@mainmatter\xauat@headerfont\xauatUniversityCN\xauatDegreePaperCN\else\xauat@headerfont\leftmark\fi}%
  \fancyfoot[RO,LE]{\xauat@pagefont\thepage}%
  \renewcommand{\headrule}{\xauat@headrule}%
  \renewcommand{\footrulewidth}{0pt}%
}

\makeatletter
\renewcommand\frontmatter{%
  \xauatcleardoublepage
  \@mainmatterfalse
  \pagenumbering{Roman}%
  \pagestyle{xauat@front}%
}
\renewcommand\mainmatter{%
  \xauatcleardoublepage
  \@mainmattertrue
  \pagenumbering{arabic}%
  \pagestyle{xauat@main}%
}
\renewcommand\backmatter{%
  \xauatcleardoublepage
  \@mainmatterfalse
}
\makeatother

\renewcommand{\chaptermark}[1]{%
  \markboth{\CTEXifname{\CTEXthechapter\quad}{}#1}{\CTEXifname{\CTEXthechapter\quad}{}#1}%
}

\renewcommand{\appendixname}{附录}
\ctexset{
  chapter = {
    name = {第\ ,\ 章},
    number = \arabic{chapter},
    aftername = \quad,
    format = \centering\heiti\zihao{3},
    beforeskip = 22bp,
    afterskip = 22bp
  },
  section = {
    format = \raggedright\heiti\zihao{4},
    beforeskip = 11bp,
    afterskip = 11bp,
    aftername = \quad
  },
  subsection = {
    format = \raggedright\songti\bfseries\zihao{-4},
    beforeskip = 11bp,
    afterskip = 11bp,
    aftername = \quad
  }
}

\makeatletter
\newcommand{\xauat@toc@entry@font}{%
  \normalfont\rmfamily\heiti\zihao{-4}%
  \setlength{\baselineskip}{\xauat@toc@entryLineSkip}\selectfont
}
\newcommand{\xauat@toc@chapter@font}{\xauat@toc@entry@font}
\titlecontents{chapter}
  [0pt]
  {\xauat@toc@chapter@font}
  {\contentspush{\thecontentslabel\quad}}
  {}
  {\titlerule*[0.5em]{.}\contentspage}
\titlecontents{section}
  [1em]
  {\xauat@toc@entry@font}
  {\contentspush{\thecontentslabel\quad}}
  {}
  {\titlerule*[0.5em]{.}\contentspage}
\titlecontents{subsection}
  [2em]
  {\xauat@toc@entry@font}
  {\contentspush{\thecontentslabel\quad}}
  {}
  {\titlerule*[0.5em]{.}\contentspage}
\makeatother

\setcounter{secnumdepth}{3}
\setcounter{tocdepth}{3}
\linespread{1.5}
\setlength{\parindent}{2em}

\AtBeginDocument{\pagestyle{xauat@front}}

\makeatother

\endinput
