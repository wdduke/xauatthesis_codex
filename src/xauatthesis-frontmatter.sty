\newcommand{\xauat@cover@en}{%
  \thispagestyle{xauat@empty}%
  \xauat@preparecoveren
  \noindent\hbox to \textwidth{%
    \hfil
    \vbox to \textheight{%
      \hsize=\textwidth
      \centering\rmfamily
      % EN-title: first title-line glyph center -> text block top ~= 1 cm.
      \vskip\xauat@enCoverTopSkip
      \usebox{\xauat@enTitleBox}%
      % Prefer 5.4 cm here, then shrink this gap first when the page is full.
      \vskip\xauat@enTitleStatementGap
      \usebox{\xauat@enStatementBox}%
      \vskip\xauat@enStatementAuthorGap
      \usebox{\xauat@enAuthorBox}%
      \vskip\xauat@enAuthorDisciplineGap
      \usebox{\xauat@enDisciplineBox}%
      \vskip\xauat@enDisciplineBottomGap
      \vss
    }%
    \hfil
  }\par
}

