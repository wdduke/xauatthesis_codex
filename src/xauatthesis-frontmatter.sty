\newcommand{\xauat@shrinkcoverengap}[2]{%
  \setlength{\xauat@enCoverShrinkRoom}{\dimexpr#1-\xauat@enComponentGapMin\relax}%
  \ifdim\xauat@enCoverOverflow>0pt
    \ifdim\xauat@enCoverOverflow<\xauat@enCoverShrinkRoom
      \setlength{#2}{\dimexpr#1-\xauat@enCoverOverflow\relax}%
      \setlength{\xauat@enCoverOverflow}{0pt}%
    \else
      \setlength{#2}{\xauat@enComponentGapMin}%
      \addtolength{\xauat@enCoverOverflow}{-\xauat@enCoverShrinkRoom}%
    \fi
  \fi
}
\newcommand{\xauat@preparecoveren}{%
  \sbox{\xauat@enTitleBox}{%
    \begin{minipage}{\textwidth}
      \centering\rmfamily
      \xauat@covertitleen{\xauatTitleEN}%
    \end{minipage}%
  }%
  \sbox{\xauat@enStatementBox}{%
    \begin{minipage}{\textwidth}
      \centering\xauat@cover@en@statement@font
      \xauat@coverstatementen
    \end{minipage}%
  }%
  \sbox{\xauat@enAuthorBox}{%
    \begin{minipage}{\textwidth}
      \centering\xauat@cover@en@author@font
      \xauat@coverauthoren
    \end{minipage}%
  }%
  \sbox{\xauat@enDisciplineBox}{%
    \begin{minipage}{\textwidth}
      \centering\xauat@cover@en@discipline@font
      \xauat@coverdisciplineen
    \end{minipage}%
  }%
  \setlength{\xauat@enTitleStatementGap}{\xauat@enTitleStatementPreferredGap}%
  \setlength{\xauat@enStatementAuthorGap}{\xauat@enStatementAuthorPreferredGap}%
  \setlength{\xauat@enAuthorDisciplineGap}{\xauat@enAuthorDisciplinePreferredGap}%
  \setlength{\xauat@enCoverNaturalHeight}{%
    \dimexpr
      \xauat@enCoverTopSkip
      +\ht\xauat@enTitleBox+\dp\xauat@enTitleBox
      +\xauat@enTitleStatementGap
      +\ht\xauat@enStatementBox+\dp\xauat@enStatementBox
      +\xauat@enStatementAuthorGap
      +\ht\xauat@enAuthorBox+\dp\xauat@enAuthorBox
      +\xauat@enAuthorDisciplineGap
      +\ht\xauat@enDisciplineBox+\dp\xauat@enDisciplineBox
      +\xauat@enDisciplineBottomGap
    \relax}%
  \setlength{\xauat@enCoverOverflow}{\dimexpr\xauat@enCoverNaturalHeight-\textheight\relax}%
  \ifdim\xauat@enCoverOverflow>0pt
    \setlength{\xauat@enCoverShrinkRoom}{%
      \dimexpr\xauat@enTitleStatementPreferredGap-\xauat@enTitleStatementMinGap\relax}%
    \ifdim\xauat@enCoverOverflow<\xauat@enCoverShrinkRoom
      \setlength{\xauat@enTitleStatementGap}{%
        \dimexpr\xauat@enTitleStatementPreferredGap-\xauat@enCoverOverflow\relax}%
      \setlength{\xauat@enCoverOverflow}{0pt}%
    \else
      \setlength{\xauat@enTitleStatementGap}{\xauat@enTitleStatementMinGap}%
      \addtolength{\xauat@enCoverOverflow}{-\xauat@enCoverShrinkRoom}%
    \fi
    \xauat@shrinkcoverengap{\xauat@enStatementAuthorPreferredGap}{\xauat@enStatementAuthorGap}%
    \xauat@shrinkcoverengap{\xauat@enAuthorDisciplinePreferredGap}{\xauat@enAuthorDisciplineGap}%
  \fi
}

