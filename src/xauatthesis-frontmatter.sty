\newcommand{\xauat@coverinfotablecn}{%
  \begingroup
    \renewcommand{\arraystretch}{1}%
    \sbox{\xauat@coverinfotablebox}{%
      \begin{tabular}{@{}m{3.43cm}@{}m{8.88cm}@{}}
        \xauat@coverrowcn{作者姓名}{\xauatBlindCN{\xauatAuthorCN}}%
        \xauat@coverrowcn{学\hspace{2\ccwd}号}{\xauatBlindID{\xauatStudentID}}%
        \xauat@coverrowcn{所在学院}{\xauatBlindCN{\xauatSchoolCN}}%
        \xauat@coverrowcn{\xauat@covermajorlabelcn}{\xauatMajorValueCN}%
        \xauat@supervisorblockcn
        \xauat@coverrowcn{答辩日期}{\xauatDefenseDateCN}%
      \end{tabular}%
    }%
    \ifxauat@debug@covertablebox
      \begingroup
        \color{red}%
        \dimen@=\dimexpr\ht\xauat@coverinfotablebox+\dp\xauat@coverinfotablebox\relax
        \dimen2=\wd\xauat@coverinfotablebox
        \dimen4=\dimexpr\dimen@-0.8pt\relax
        \makebox[0pt][l]{%
          \raisebox{-\dp\xauat@coverinfotablebox}[0pt][0pt]{%
            \vbox{%
              \offinterlineskip
              \hrule height 0.4pt
              \hbox to \dimen2{%
                \vrule width 0.4pt height \dimen4
                \hfil
                \vrule width 0.4pt height \dimen4
              }%
              \hrule height 0.4pt
            }%
          }%
        }%
      \endgroup
    \fi
    \usebox{\xauat@coverinfotablebox}%
  \endgroup
}

