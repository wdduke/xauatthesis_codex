\NeedsTeXFormat{LaTeX2e}[2022/06/01]
\ProvidesFile{xauatthesis-backmatter.sty}
  [2026/05/06 v0.1 Back matter tools for XAUAT thesis template]

\makeatletter

\newcommand{\xauat@achievements}{}
\newcommand{\xauat@acknowledgement}{}
\newif\ifxauat@achievementsprinted
\newif\ifxauat@acknowledgementprinted
\NewEnviron{xauatachievements}{%
  \global\let\xauat@achievements\BODY
  \ifxauat@documentstarted
    \printXAUATachievements
  \fi
}
\NewEnviron{xauatacknowledgement}{%
  \global\let\xauat@acknowledgement\BODY
  \ifxauat@documentstarted
    \printXAUATacknowledgement
  \fi
}

\newcommand{\printXAUATachievements}{%
  \ifxauat@achievementsprinted\else
    \global\xauat@achievementsprintedtrue
    \xauatifblind
      {%
        \xauatifblindachievementhide
          {%
            \PackageWarning{xauatthesis}
              {Blind review mode hides achievements by default}%
          }
          {%
            \xauatifblindachievementanonymous
              {%
                \xauat@achievement@start{\xauatAchievementsName}%
                盲审版科研成果已匿名化处理。%
              }
              {%
                \xauat@achievement@start{\xauatAchievementsName}%
                \xauat@achievements
              }%
          }%
      }
      {%
        \xauat@achievement@start{\xauatAchievementsName}%
        \xauat@achievements
      }%
  \fi
}

\newcommand{\printXAUATacknowledgement}{%
  \ifxauat@acknowledgementprinted\else
    \global\xauat@acknowledgementprintedtrue
    \xauatifblind
      {%
        \xauatifblindacknowledgementhide
          {%
            \PackageWarning{xauatthesis}
              {Blind review mode hides acknowledgement by default}%
          }
          {%
            \xauatifblindacknowledgementplaceholder
              {%
                \xauat@acknowledgements@start{\xauatAcknowledgementName}%
                本页为盲审版致谢占位，不显示可能泄露身份的信息。%
              }
              {%
                \xauat@acknowledgements@start{\xauatAcknowledgementName}%
                \xauat@acknowledgement
              }%
          }%
      }
      {%
        \xauat@acknowledgements@start{\xauatAcknowledgementName}%
        \xauat@acknowledgement
      }%
  \fi
}
\let\printXAUATAcknowledgement\printXAUATacknowledgement

\makeatother

\endinput
